{
  "screen": {
    "id": "console-home",
    "title": "Console Home",
    "source": "design-b/console.html"
  },
  "version": 1,
  "state_classes": {
    "inherit": true
  },
  "interactions": [
    {
      "trigger": "sample-open-btn",
      "action": "opens",
      "target": "sample-panel"
    }
  ],
  "elements": [
    {
      "anchor": "sample-open-btn",
      "role": "打开面板按钮",
      "copy_key": "sample.open"
    },
    {
      "anchor": "sample-panel",
      "role": "操作面板（深色玻璃，light/dark 主题不变）",
      "states": [
        "panel"
      ],
      "contracts": {
        "surface": "dark-glass",
        "themeInvariant": true,
        "motion": {
          "portrait": "slide-up",
          "landscape": "slide-in-right"
        }
      }
    }
  ],
  "states": {
    "designed": [
      {
        "id": "default",
        "note": "落地态"
      },
      {
        "id": "panel",
        "note": "面板展开态"
      }
    ],
    "delegated": [
      {
        "state": "offline",
        "to": "backend",
        "contract_ref": "docs/sample-api.yaml",
        "status": "open"
      },
      {
        "state": "offline-subsection",
        "to": "backend",
        "contract_ref": "docs/sample-api.yaml#offline-recovery",
        "status": "open",
        "note": "fixture：文件在树内但 #fragment 子段未冻结——不触发裁决期限"
      }
    ]
  }
}